# 火山引擎方舟（Ark）配置 —— 在 Coolify 的 Environment Variables 中填写
# 1) 从火山引擎方舟控制台 -> API Key 管理 创建一个 API Key
ARK_API_KEY=your_ark_api_key_here
# 2) 模型 ID：可填方舟开通的模型名（如 doubao-seed-1-6-250615 / doubao-1-5-pro-32k）
#    或推理接入点 ID（ep-xxxxxxxx）
ARK_MODEL=doubao-seed-1-6-250615
# 可选，默认即可
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PORT=3000
