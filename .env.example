# 火山引擎方舟（Ark）配置 —— 在 Coolify 的 Environment Variables 中填写
# 1) 从火山引擎方舟控制台 -> API Key 管理 创建一个 API Key
ARK_API_KEY=your_ark_api_key_here
# 2) 模型 ID：可填方舟开通的模型名（如 doubao-seed-1-6-250615 / doubao-1-5-pro-32k）
#    或推理接入点 ID（ep-xxxxxxxx）
ARK_MODEL=doubao-seed-1-6-250615
# 可选，默认即可
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PORT=3000

# ===== 可选：安全与成本（均有合理默认值，不填即可）=====
# 单次回答 token 上限（成本保护，默认 1024）
ARK_MAX_TOKENS=1024
# 每 IP 每分钟请求上限（默认 12）
RATE_LIMIT=12
# 全局并发上游流上限（默认 8）
MAX_CONCURRENT=8
# 上游总超时毫秒（默认 60000）
UPSTREAM_TIMEOUT_MS=60000
# 默认不开放跨域；仅当页面要被其他域名嵌入时填写允许的来源（如 https://example.com）
ALLOWED_ORIGIN=
ANALYTICS_URL=
ANALYTICS_TOKEN=
