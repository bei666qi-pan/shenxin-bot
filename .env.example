# VerseCraft（OpenAI 兼容 API）—— 在 Coolify 的 Environment Variables 中填写
# API Key 仅填写在部署环境，切勿提交到仓库。
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-one
LLM_BASE_URL=https://newkey.versecraft.cn/v1
PORT=3000

# ===== 可选：安全与成本（均有合理默认值，不填即可）=====
# 单次回答 token 上限（成本保护，默认 1024）
LLM_MAX_TOKENS=1024
# 每 IP 每分钟请求上限（默认 12）
RATE_LIMIT=12
# 全局并发上游流上限（默认 8）
MAX_CONCURRENT=8
# 上游总超时毫秒（默认 60000）
UPSTREAM_TIMEOUT_MS=60000
# 默认不开放跨域；仅当页面要被其他域名嵌入时填写允许的来源（如 https://example.com）
ALLOWED_ORIGIN=
ANALYTICS_URL=
ANALYTICS_TOKEN=
